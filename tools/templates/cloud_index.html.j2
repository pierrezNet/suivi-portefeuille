<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#000091">
    <meta name="robots" content="noindex, nofollow">
    <title>Suivi Portefeuille</title>

    {# --- PWA --- #}
    <link rel="manifest" href="manifest.json">
    <link rel="icon" type="image/svg+xml" href="icon.svg">
    <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon-180.png">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Portefeuille">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <style>{{ css_inline|safe }}

/* Modale mot de passe */
.modale-fond {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.modale {
  background: #fff;
  padding: 1.5rem 1.25rem;
  border-radius: 6px;
  width: min(90vw, 380px);
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}
.modale h2 { margin: 0 0 0.5rem; font-size: 1.1rem; }
.modale label { display: block; margin-top: 0.85rem; font-size: 0.85rem; color: var(--gris-muet); }
.modale input[type="password"] {
  width: 100%;
  padding: 0.6rem 0.7rem;
  font-size: 1rem;
  border: 1px solid var(--gris-bordure);
  border-radius: 4px;
  margin-top: 0.25rem;
  box-sizing: border-box;
}
.modale .ligne-checkbox {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: 0.7rem;
  font-size: 0.85rem;
  color: var(--gris-texte);
}
.modale button {
  width: 100%;
  margin-top: 1rem;
  padding: 0.7rem;
  background: var(--bleu-france);
  color: #fff;
  border: none;
  border-radius: 4px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
}
.modale button:hover { background: #1212a8; }
.modale .erreur {
  color: var(--rouge);
  font-size: 0.85rem;
  margin-top: 0.5rem;
  display: none;
}
.modale .erreur.visible { display: block; }
.btn-recharger {
  background: transparent;
  border: 1px solid rgba(255,255,255,0.4);
  color: #fff;
  padding: 0.25rem 0.6rem;
  border-radius: 3px;
  font-size: 0.78rem;
  cursor: pointer;
}
.btn-recharger:hover { background: rgba(255,255,255,0.15); }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="container">
        <h1>💼 Suivi Portefeuille</h1>
        <span style="display:flex;gap:0.5rem;align-items:center">
          <small id="genere-le">—</small>
          <button class="btn-recharger" id="btn-recharger" title="Forcer le rechargement des données">🔄</button>
          <button class="btn-recharger" id="btn-oublier" title="Effacer le mot de passe mémorisé">🔑</button>
        </span>
      </div>
    </header>
    <main class="container" id="app">
      <p>Chargement…</p>
    </main>
    <footer class="bas-page">
      <div class="container">
        <small>Lecture seule · Données chiffrées · 100&nbsp;% client-side</small>
      </div>
    </footer>

    <div class="modale-fond" id="modale-fond" style="display:none">
      <form class="modale" id="modale-form">
        <h2>🔒 Mot de passe</h2>
        <p style="margin:0;font-size:0.88rem;color:var(--gris-muet)">
          Saisis le mot de passe utilisé lors de la publication pour déchiffrer les données.
        </p>
        <label>Mot de passe
          <input type="password" id="mdp" autocomplete="current-password" required minlength="8">
        </label>
        <div class="ligne-checkbox">
          <input type="checkbox" id="memoriser" checked>
          <label for="memoriser" style="margin:0">Mémoriser sur cet appareil</label>
        </div>
        <button type="submit">Déchiffrer</button>
        <div class="erreur" id="erreur-mdp">Mot de passe incorrect.</div>
      </form>
    </div>

    <script>{{ js_inline|safe }}</script>
    <script>
      // Enregistrement du service worker (PWA v2.0)
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("sw.js")
            .catch((e) => console.warn("Service worker non enregistré :", e));
        });
      }
    </script>
  </body>
</html>
